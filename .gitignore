# ========================
# 编译产物 (WSL2 环境下主要生成 Linux 格式)
# ========================
*.o
*.out
*.so
*.a

# ========================
# 构建目录 (VS Code + CMake Tools 常见)
# ========================
build/
cmake-build-*/

# ========================
# CMake 自动生成的文件 (如果你在根目录直接 cmake ..)
# ========================
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile

# ========================
# 编辑器配置 (VS Code)
# ========================
.vscode/

# ========================
# 调试与系统文件
# ========================
core        # WSL2 崩溃产生的 core dump
*.swp       # 如果你偶尔用 vim 修改文件(现在没用)
